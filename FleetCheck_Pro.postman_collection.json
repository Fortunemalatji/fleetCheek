{
	"info": {
		"_postman_id": "f1eet-check-pro-full-crud-0127",
		"name": "FleetCheck Pro - Complete API (Secured)",
		"description": "Full secured API collection for FleetCheck Pro: CRUD, lookups, and the 4-zone inspection checklist with JWT Auth.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "base_url", "value": "http://localhost:8080", "type": "string" },
		{ "key": "inspection_id", "value": "", "type": "string" },
		{ "key": "jwt_token", "value": "", "type": "string" }
	],
	"auth": {
		"type": "bearer",
		"bearer": [ { "key": "token", "value": "{{jwt_token}}", "type": "string" } ]
	},
	"item": [
		{
			"name": "0. Authentication",
			"item": [
				{
					"name": "Login",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"userId\": \"admin\",\n  \"pin\": \"1234\"\n}", "options": { "raw": { "language": "json" } } },
						"url": "{{base_url}}/api/auth/login",
						"description": "Returns a JWT. Copy it to the {{jwt_token}} collection variable."
					}
				},
				{
					"name": "Change PIN (Authenticated)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"userId\": \"admin\",\n  \"pin\": \"1234\"\n}", "options": { "raw": { "language": "json" } } },
						"url": "{{base_url}}/api/auth/set-pin",
						"description": "Used to change the PIN for an existing user."
					}
				}
			]
		},
		{
			"name": "Users",
			"item": [
				{ "name": "Get All", "request": { "method": "GET", "url": "{{base_url}}/api/users" } },
				{ "name": "Create User (with PIN)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"userId\": \"0000827008\",\n  \"username\": \"alfredo\",\n  \"fullName\": \"Alfredo Reid\",\n  \"fleetGroup\": \"Northern Cape\",\n  \"role\": { \"id\": 2 },\n  \"pin\": \"1234\"\n}", "options": { "raw": { "language": "json" } } }, "url": "{{base_url}}/api/users", "description": "Include 'fleetGroup' (mandatory) and nested 'role' object." } }
			]
		},
		{
			"name": "Lookups",
			"item": [
				{ "name": "Roles", "request": { "method": "GET", "url": "{{base_url}}/api/roles" } },
				{ "name": "Checklist Templates", "request": { "method": "GET", "url": "{{base_url}}/api/inspections/checklist/templates" } }
			]
		},
		{
			"name": "Vehicles",
			"item": [
				{ "name": "Get All", "request": { "method": "GET", "url": "{{base_url}}/api/vehicles" } },
				{ "name": "Create Vehicle (with Photos)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"vehicleId\": \"ST2832\",\n  \"categoryId\": 2,\n  \"isActive\": true,\n  \"fleetGroup\": \"PH4\",\n  \"frontPhotoUrl\": \"https://example.com/front.jpg\",\n  \"backPhotoUrl\": \"https://example.com/back.jpg\",\n  \"leftPhotoUrl\": \"https://example.com/left.jpg\",\n  \"rightPhotoUrl\": \"https://example.com/right.jpg\"\n}", "options": { "raw": { "language": "json" } } }, "url": "{{base_url}}/api/vehicles" } }
			]
		},
		{
			"name": "Shipments",
			"item": [
				{ "name": "Get All", "request": { "method": "GET", "url": "{{base_url}}/api/shipments" } },
				{ "name": "Create Shipment (Duo)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"shipmentId\": \"159495\",\n  \"dispatchDate\": \"2026-03-21\",\n  \"driver\": { \"userId\": \"0000827008\" },\n  \"coDriverId\": \"0000827009\",\n  \"tripType\": \"DUO\",\n  \"fleetGroup\": \"PH4\",\n  \"status\": { \"id\": 1 },\n  \"vehicle\": { \"vehicleId\": \"TT3626\" }\n}", "options": { "raw": { "language": "json" } } }, "url": "{{base_url}}/api/shipments" } }
			]
		},
		{
			"name": "Inspections",
			"item": [
				{
					"name": "1. Start Inspection",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"shipment\": { \"shipmentId\": \"159494\" },\n  \"gpsLocation\": \"-26.123, 28.456\"\n}", "options": { "raw": { "language": "json" } } },
						"url": "{{base_url}}/api/inspections/start"
					}
				},
				{
					"name": "2. Submit Checklist (One Shot)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "[\n  { \"itemCode\": \"GAUGES\",            \"response\": \"YES\", \"remarks\": \"\", \"startTime\": \"2026-03-22T10:00:00\", \"endTime\": \"2026-03-22T10:00:15\" },\n  { \"itemCode\": \"TYRES_RIMS\",        \"response\": \"NO\",  \"remarks\": \"Left front worn\", \"photoUrl\": \"https://example.com/worn_tyre.jpg\", \"startTime\": \"2026-03-22T10:00:16\", \"endTime\": \"2026-03-22T10:00:45\" }\n]", "options": { "raw": { "language": "json" } } },
						"url": "{{base_url}}/api/inspections/{{inspection_id}}/checklist"
					}
				},
				{
					"name": "3. Follow-up: Mark Fixed",
					"request": {
						"method": "PATCH",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"isFixed\": true,\n  \"remarks\": \"Tyre replaced by workshop\"\n}", "options": { "raw": { "language": "json" } } },
						"url": "{{base_url}}/api/inspections/{{inspection_id}}/checklist/TYRES_RIMS"
					}
				},
				{
					"name": "4. End Inspection",
					"request": {
						"method": "POST",
						"url": {
							"raw": "{{base_url}}/api/inspections/{{inspection_id}}/end?driverSig=Mr Maahlo&supervisorSig=Mr Morele&securitySig=Mr Skhosana",
							"query": [
								{ "key": "driverSig", "value": "Mr Maahlo" },
								{ "key": "supervisorSig", "value": "Mr Morele" },
								{ "key": "securitySig", "value": "Mr Skhosana" }
							]
						}
					}
				},
				{
					"name": "5. Verify Gate Pass",
					"request": {
						"method": "GET",
						"url": "{{base_url}}/api/inspections/{{inspection_id}}/verify"
					}
				}
			]
		}
	]
}
